# Copy to .env and fill in your key to enable the autonomous (LLM-driven) agent.
#   cp .env.example .env
# .env is git-ignored. Without a key the agent runs in deterministic scripted mode.

# Required for autonomous mode. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model the agent plans with (default: claude-sonnet-4-6).
# CORNERSTONE_AGENT_MODEL=claude-sonnet-4-6
